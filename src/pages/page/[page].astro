---
import { getCollection } from 'astro:content';
import Blog from '../../layouts/Blog.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { SITE } from '../../config';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  const totalPages = Math.ceil(allPosts.length / SITE.postsPerPage);
  const paths = [];

  for (let page = 2; page <= totalPages; page++) {
    const start = (page - 1) * SITE.postsPerPage;
    const posts = allPosts.slice(start, start + SITE.postsPerPage);
    paths.push({
      params: { page: String(page) },
      props: { posts, page, totalPages },
    });
  }

  return paths;
}

const { posts, page, totalPages } = Astro.props;
const prevUrl = page === 2 ? '/' : `/page/${page - 1}`;
const nextUrl = page < totalPages ? `/page/${page + 1}` : undefined;
---

<Blog title={`Página ${page}`}>
  {posts.map((post: any) => (
    <PostCard
      title={post.data.title}
      slug={post.data.slug}
      date={post.data.date}
      description={post.data.description}
      category={post.data.category}
      tags={post.data.tags}
    />
  ))}
  <Pagination
    currentPage={page}
    totalPages={totalPages}
    prevUrl={prevUrl}
    nextUrl={nextUrl}
  />
</Blog>
