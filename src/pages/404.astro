---
import Blog from '../layouts/Blog.astro';
---

<Blog title="Página não encontrada">
  <div class="py-16 text-center">
    <p class="text-7xl font-bold text-zinc-200 dark:text-zinc-800">404</p>
    <h1 class="mt-4 text-2xl font-bold text-zinc-900 dark:text-zinc-100">
      Página não encontrada
    </h1>
    <p class="mt-2 text-zinc-500 dark:text-zinc-400">
      A página que você está procurando não existe.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors"
    >
      Voltar ao início
    </a>
  </div>
</Blog>
