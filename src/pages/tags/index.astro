---
import { getCollection } from 'astro:content';
import Blog from '../../layouts/Blog.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const tagMap = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);

function tagToSlug(tag: string) {
  return tag.toLowerCase().replace(/\s+/g, '-');
}
---

<Blog title="Tags">
  <div>
    <h1 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 mb-8">Tags</h1>
    {tags.length === 0 ? (
      <p class="text-zinc-500 dark:text-zinc-400">Nenhuma tag encontrada.</p>
    ) : (
      <div class="flex flex-wrap gap-3">
        {tags.map(([tag, count]) => (
          <a
            href={`/tag/${tagToSlug(tag)}`}
            class="inline-flex items-center gap-2 px-4 py-2 bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 rounded-full hover:bg-indigo-100 dark:hover:bg-indigo-950 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors font-medium text-sm"
          >
            #{tag}
            <span class="text-xs text-zinc-400 dark:text-zinc-500">{count}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</Blog>
