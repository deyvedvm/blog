---
import { getCollection } from 'astro:content';
import Blog from '../../layouts/Blog.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { SITE } from '../../config';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);

  const tagMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      const slug = tag.toLowerCase().replace(/\s+/g, '-');
      if (!tagMap.has(slug)) tagMap.set(slug, []);
      tagMap.get(slug)!.push(post);
    }
  }

  return [...tagMap.entries()].map(([tagSlug, posts]) => {
    posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const tagName = posts[0]?.data.tags.find(
      (t) => t.toLowerCase().replace(/\s+/g, '-') === tagSlug
    ) ?? tagSlug;
    return {
      params: { tag: tagSlug },
      props: { posts, tagName, totalPages: Math.ceil(posts.length / SITE.postsPerPage) },
    };
  });
}

const { posts: allTagPosts, tagName, totalPages } = Astro.props;
const tag = Astro.params.tag;
const pagePosts = allTagPosts.slice(0, SITE.postsPerPage);
---

<Blog title={`Tag: ${tagName}`}>
  <div>
    <header class="mb-8">
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-1">Tag</p>
      <h1 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">#{tagName}</h1>
    </header>

    {pagePosts.map((post: any) => (
      <PostCard
        title={post.data.title}
        slug={post.data.slug}
        date={post.data.date}
        description={post.data.description}
        category={post.data.category}
        tags={post.data.tags}
      />
    ))}

    <Pagination
      currentPage={1}
      totalPages={totalPages}
      nextUrl={totalPages > 1 ? `/tag/${tag}/2` : undefined}
    />
  </div>
</Blog>
