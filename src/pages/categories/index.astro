---
import { getCollection } from 'astro:content';
import Blog from '../../layouts/Blog.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const categoryMap = new Map<string, number>();
for (const post of posts) {
  if (post.data.category) {
    categoryMap.set(post.data.category, (categoryMap.get(post.data.category) ?? 0) + 1);
  }
}

const categories = [...categoryMap.entries()].sort((a, b) => b[1] - a[1]);

function categoryToSlug(cat: string) {
  return cat.toLowerCase().replace(/\s+/g, '-');
}
---

<Blog title="Categorias">
  <div>
    <h1 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 mb-8">Categorias</h1>
    {categories.length === 0 ? (
      <p class="text-zinc-500 dark:text-zinc-400">Nenhuma categoria encontrada.</p>
    ) : (
      <div class="flex flex-wrap gap-3">
        {categories.map(([cat, count]) => (
          <a
            href={`/category/${categoryToSlug(cat)}`}
            class="inline-flex items-center gap-2 px-4 py-2 bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 rounded-full hover:bg-indigo-100 dark:hover:bg-indigo-950 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors font-medium text-sm"
          >
            {cat}
            <span class="text-xs text-zinc-400 dark:text-zinc-500">{count}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</Blog>
