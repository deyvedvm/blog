---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;

function tagToSlug(tag: string) {
  return tag.toLowerCase().replace(/\s+/g, '-');
}
---

{tags.length > 0 && (
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <a
        href={`/tag/${tagToSlug(tag)}`}
        class="inline-block px-3 py-1 text-xs font-medium bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 rounded-full hover:bg-indigo-100 dark:hover:bg-indigo-950 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors"
      >
        #{tag}
      </a>
    ))}
  </div>
)}
